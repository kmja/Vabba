# Cloudflare Pages headers (https://developers.cloudflare.com/pages/configuration/headers/).
# Next copies public/ into the exported out/ folder at build time.

# Fingerprinted build assets never change — cache them hard.
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# The Next-generated OG image is written without a file extension, so declare
# its type explicitly — otherwise nosniff (below) makes crawlers reject it.
/opengraph-image
  Content-Type: image/png

# Conservative security headers for every response.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
